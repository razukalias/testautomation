<Window x:Class="Test_Automation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Test_Automation"
        mc:Ignorable="d"
        Title="Test Automation" Height="650" Width="1100">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="#D0D0D0" BorderThickness="0,0,1,0" Background="#FAFAFA">
            <DockPanel Margin="12">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="AddProjectButton"
                    Height="32"
                    Width="100"
                    Margin="0,0,8,0"
                    Content="Add Project"
                    Click="AddProjectButton_Click" />
                <Button x:Name="SaveProjectButton"
                    Height="32"
                    Width="90"
                    Margin="0,0,8,0"
                    Content="Save JSON"
                    Click="SaveProjectButton_Click" />
                <Button x:Name="LoadProjectButton"
                    Height="32"
                    Width="90"
                    Content="Load JSON"
                    Click="LoadProjectButton_Click" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="RunTestPlanButton"
                    Height="32"
                    Width="120"
                    Margin="0,0,8,0"
                    Content="Run TestPlan"
                    Click="RunTestPlanButton_Click" />
                <TextBlock Text="Env:" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold" />
                <ComboBox x:Name="EnvironmentComboBox"
                          Height="32"
                          Width="140"
                          VerticalContentAlignment="Center"
                          ItemsSource="{Binding EnvironmentNames}"
                          SelectedItem="{Binding ActiveEnvironmentName, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

                <TreeView x:Name="PlanTreeView"
                          ItemsSource="{Binding RootNodes}"
                          AllowDrop="True"
                          SelectedItemChanged="PlanTreeView_SelectedItemChanged"
                          PreviewMouseLeftButtonDown="PlanTreeView_PreviewMouseLeftButtonDown"
                          PreviewMouseMove="PlanTreeView_PreviewMouseMove"
                          PreviewMouseRightButtonDown="PlanTreeView_PreviewMouseRightButtonDown"
                          DragOver="PlanTreeView_DragOver"
                          Drop="PlanTreeView_Drop">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            <Setter Property="AllowDrop" Value="True" />
                            <EventSetter Event="DragEnter" Handler="TreeViewItem_DragEnter" />
                            <EventSetter Event="DragLeave" Handler="TreeViewItem_DragLeave" />
                            <EventSetter Event="DragOver" Handler="TreeViewItem_DragOver" />
                            <EventSetter Event="Drop" Handler="TreeViewItem_Drop" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                    <Setter Property="Background" Value="#FFFFC107" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding DisplayName}" />
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Background="#FFFFFF" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="3*" />
            </Grid.RowDefinitions>

            <Border BorderBrush="#D8D8D8" BorderThickness="1" Padding="12" CornerRadius="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                    <TextBlock Text="Node Editor" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Type" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding SelectedNode.Type, TargetNullValue=Select a node}" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Id" />
                        <TextBox Grid.Column="1" Text="{Binding SelectedNode.Id, Mode=OneWay}" IsReadOnly="True" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Name" />
                        <TextBox Grid.Column="1" Text="{Binding SelectedNode.Name, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Enabled" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding SelectedNode.IsEnabled}" VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Clear Children Preview"
                                Width="180"
                                Click="ClearChildrenPreviewButton_Click"
                                Visibility="{Binding HasSelectedNodeChildren, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>

                    <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsProjectSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Project" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Description" />
                                <TextBox Grid.Column="1" Text="{Binding ProjectDescription, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Environment" />
                                <TextBox Grid.Column="1" Text="{Binding ProjectEnvironment, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <TextBlock Text="Variables" FontWeight="SemiBold" Margin="0,10,0,6" />
                            <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding SelectedNode.Variables}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Margin="0,0,6,0" Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBox Grid.Column="1" Margin="0,0,6,0" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button Grid.Column="2" Content="X" Width="26" Height="24" Click="RemoveProjectVariableButton_Click" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="Add Variable" Width="110" Click="AddProjectVariableButton_Click" />
                            </StackPanel>

                            <!-- Environments Section -->
                            <TextBlock Text="Environments" FontWeight="SemiBold" Margin="0,14,0,6" />
                            <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ProjectEnvironments}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#D0D8E8" BorderThickness="1" CornerRadius="3"
                                                    Padding="8" Margin="0,0,0,8" Background="#F4F8FF">
                                                <StackPanel>
                                                    <!-- Name + BaseUrl row -->
                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="70" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                                                   Text="Name" FontWeight="SemiBold" />
                                                        <TextBox Grid.Column="1" Margin="0,0,6,0"
                                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                                        <Button Grid.Column="2" Content="Delete" Width="54" Height="24"
                                                                Click="DeleteEnvironmentButton_Click" />
                                                    </Grid>
                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="70" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                                                   Text="Base URL" />
                                                        <TextBox Grid.Column="1"
                                                                 Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                                                    </Grid>
                                                    <!-- Per-environment variables -->
                                                    <TextBlock Text="Variables" FontSize="11" Margin="0,4,0,4"
                                                               Foreground="#555" />
                                                    <ItemsControl ItemsSource="{Binding Variables}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBox Grid.Column="0" Margin="0,0,4,0"
                                                                             Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}" />
                                                                    <TextBox Grid.Column="1" Margin="0,0,4,0"
                                                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                                                    <Button Grid.Column="2" Content="X" Width="26" Height="24"
                                                                            Click="RemoveEnvVariableButton_Click" />
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <Button Content="+ Add Variable" HorizontalAlignment="Left"
                                                            Margin="0,4,0,0" Width="110"
                                                            Click="AddEnvVariableButton_Click" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="Add Environment" Width="130" Click="AddEnvironmentButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                        <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,6,0,8"
                            Visibility="{Binding IsHttpSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="HTTP" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Method" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding HttpMethodOptions}"
                                          SelectedItem="{Binding HttpMethod, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="URL" />
                                <TextBox Grid.Column="1" Text="{Binding HttpUrl, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Top" Text="Body" />
                                <TextBox Grid.Column="1" Text="{Binding HttpBody, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="80" VerticalScrollBarVisibility="Auto" />
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Top" Text="Headers (JSON)" />
                                <TextBox Grid.Column="1" Text="{Binding HttpHeaders, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="60" VerticalScrollBarVisibility="Auto" />
                            </Grid>
                            <TextBlock Text="Authentication" FontWeight="SemiBold" Margin="0,10,0,6" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Type" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding AuthTypeOptions}"
                                          SelectedItem="{Binding HttpAuthType, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Username" />
                                <TextBox Grid.Column="1" Text="{Binding HttpAuthUsername, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="HttpShowBasicFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Password" />
                                <TextBox Grid.Column="1" Text="{Binding HttpAuthPassword, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="HttpShowBasicFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Bearer Token" />
                                <TextBox Grid.Column="1" Text="{Binding HttpAuthToken, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="HttpShowBearerFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="API Key Name" />
                                <TextBox Grid.Column="1" Text="{Binding HttpApiKeyName, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="HttpShowApiKeyFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="API Key Value" />
                                <TextBox Grid.Column="1" Text="{Binding HttpApiKeyValue, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="HttpShowApiKeyFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="API Key In" />
                                <TextBox Grid.Column="1" Text="{Binding HttpApiKeyLocation, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="HttpShowApiKeyFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="OAuth Token URL" />
                                <TextBox Grid.Column="1" Text="{Binding HttpOAuthTokenUrl, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="HttpShowOAuthFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="OAuth Client ID" />
                                <TextBox Grid.Column="1" Text="{Binding HttpOAuthClientId, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="HttpShowOAuthFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="OAuth Client Secret" />
                                <TextBox Grid.Column="1" Text="{Binding HttpOAuthClientSecret, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="HttpShowOAuthFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="OAuth Scope" />
                                <TextBox Grid.Column="1" Text="{Binding HttpOAuthScope, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="HttpShowOAuthFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsGraphQlSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="GraphQL" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Endpoint" />
                                <TextBox Grid.Column="1" Text="{Binding GraphQlEndpoint, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Top" Text="Query" />
                                <TextBox Grid.Column="1" Text="{Binding GraphQlQuery, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="80" VerticalScrollBarVisibility="Auto" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Top" Text="Variables" />
                                <TextBox Grid.Column="1" Text="{Binding GraphQlVariables, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="60" VerticalScrollBarVisibility="Auto" />
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Top" Text="Headers (JSON)" />
                                <TextBox Grid.Column="1" Text="{Binding GraphQlHeaders, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="60" VerticalScrollBarVisibility="Auto" />
                            </Grid>
                            <TextBlock Text="Authentication" FontWeight="SemiBold" Margin="0,10,0,6" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Type" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding AuthTypeOptions}"
                                          SelectedItem="{Binding GraphQlAuthType, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Username" />
                                <TextBox Grid.Column="1" Text="{Binding GraphQlAuthUsername, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="GraphQlShowBasicFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Password" />
                                <TextBox Grid.Column="1" Text="{Binding GraphQlAuthPassword, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="GraphQlShowBasicFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Bearer Token" />
                                <TextBox Grid.Column="1" Text="{Binding GraphQlAuthToken, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="GraphQlShowBearerFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="API Key Name" />
                                <TextBox Grid.Column="1" Text="{Binding GraphQlApiKeyName, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="GraphQlShowApiKeyFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="API Key Value" />
                                <TextBox Grid.Column="1" Text="{Binding GraphQlApiKeyValue, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="GraphQlShowApiKeyFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="API Key In" />
                                <TextBox Grid.Column="1" Text="{Binding GraphQlApiKeyLocation, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="GraphQlShowApiKeyFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="OAuth Token URL" />
                                <TextBox Grid.Column="1" Text="{Binding GraphQlOAuthTokenUrl, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="GraphQlShowOAuthFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="OAuth Client ID" />
                                <TextBox Grid.Column="1" Text="{Binding GraphQlOAuthClientId, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="GraphQlShowOAuthFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="OAuth Client Secret" />
                                <TextBox Grid.Column="1" Text="{Binding GraphQlOAuthClientSecret, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="GraphQlShowOAuthFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="OAuth Scope" />
                                <TextBox Grid.Column="1" Text="{Binding GraphQlOAuthScope, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="GraphQlShowOAuthFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                        </StackPanel>
                    </Border>

                        <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsSqlSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="SQL" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Connection" />
                                <TextBox Grid.Column="1" Text="{Binding SqlConnection, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Query" />
                                <TextBox Grid.Column="1" Text="{Binding SqlQuery, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <TextBlock Text="Authentication" FontWeight="SemiBold" Margin="0,10,0,6" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Type" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding AuthTypeOptions}"
                                          SelectedItem="{Binding SqlAuthType, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Username" />
                                <TextBox Grid.Column="1" Text="{Binding SqlAuthUsername, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="SqlShowBasicFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Password" />
                                <TextBox Grid.Column="1" Text="{Binding SqlAuthPassword, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid.Visibility>
                                    <Binding Path="SqlShowBasicFields" Converter="{StaticResource BoolToVisibilityConverter}" />
                                </Grid.Visibility>
                            </Grid>
                        </StackPanel>
                    </Border>

                        <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsTimerSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Delay (ms)" />
                            <TextBox Grid.Column="1" Text="{Binding TimerDelayMs, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>

                        <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsLoopSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Iterations" />
                            <TextBox Grid.Column="1" Text="{Binding LoopIterations, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>

                        <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsIfSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Condition" />
                            <TextBox Grid.Column="1" Text="{Binding IfCondition, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>

                        <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsThreadsSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Threads" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Count" />
                                <TextBox Grid.Column="1" Text="{Binding ThreadCount, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="RampUp (s)" />
                                <TextBox Grid.Column="1" Text="{Binding RampUpSeconds, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                        <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsAssertSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Assert" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Expected" />
                                <TextBox Grid.Column="1" Text="{Binding AssertExpected, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Actual" />
                                <TextBox Grid.Column="1" Text="{Binding AssertActual, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                        <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsVariableExtractorSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Variable Extractor" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Pattern" />
                                <TextBox Grid.Column="1" Text="{Binding ExtractorPattern, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Variable" />
                                <TextBox Grid.Column="1" Text="{Binding ExtractorVariableName, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                        <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsScriptSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Script" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Language" />
                                <TextBox Grid.Column="1" Text="{Binding ScriptLanguage, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Top" Text="Code" />
                                <TextBox Grid.Column="1" Text="{Binding ScriptCode, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="80" VerticalScrollBarVisibility="Auto" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="#E3E3E3" BorderThickness="1" Padding="8" CornerRadius="3" Margin="0,0,0,8"
                            Visibility="{Binding IsComponentSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Extract Variables" FontWeight="SemiBold" Margin="0,0,0,6" />

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Source Field" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="JSON Path" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2" Text="Variable Name" FontWeight="SemiBold" />
                            </Grid>

                            <ScrollViewer Height="100" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding SelectedNode.Extractors}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0"
                                                          Margin="0,0,6,0"
                                                          ItemsSource="{Binding DataContext.ExtractorSourceOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="True"
                                                          Text="{Binding Source, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBox Grid.Column="1" Margin="0,0,6,0" Text="{Binding JsonPath, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBox Grid.Column="2" Margin="0,0,6,0" Text="{Binding VariableName, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button Grid.Column="3" Content="X" Width="26" Height="24" Click="RemoveExtractorButton_Click" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="Add Extractor" Width="120" Click="AddExtractorButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Settings" FontWeight="SemiBold" Margin="0,8,0,8" />

                    <ScrollViewer Height="140" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SelectedNode.Settings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Margin="0,0,6,0" Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="1" Margin="0,0,6,0" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="2" Content="X" Width="26" Height="24" Click="RemoveSettingButton_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Add Setting" Width="100" Click="AddSettingButton_Click" />
                    </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Row="1"
                          Height="6"
                          Margin="0,10,0,10"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="#E0E0E0"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext" />

            <Border Grid.Row="2" BorderBrush="#D8D8D8" BorderThickness="1" Padding="8" CornerRadius="4" Margin="0,0,0,0">
                <TabControl>
                    <TabItem Header="Request">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                                <Button Content="Clear" Width="80" Click="ClearRequestButton_Click" />
                            </StackPanel>
                            <TextBox Grid.Row="1"
                                     Text="{Binding PreviewRequest}"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsReadOnly="True" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="Response">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                                <Button Content="Clear" Width="80" Click="ClearResponseButton_Click" />
                            </StackPanel>
                            <TextBox Grid.Row="1"
                                     Text="{Binding PreviewResponse}"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsReadOnly="True" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="Logs">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                                <Button Content="Clear" Width="80" Click="ClearLogsButton_Click" />
                            </StackPanel>
                            <TextBox Grid.Row="1"
                                     Text="{Binding PreviewLogs}"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsReadOnly="True" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="Flow JSON">
                        <TextBox Text="{Binding JsonPreview}"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 IsReadOnly="True" />
                    </TabItem>
                    <TabItem Header="Variables">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                                <Button Content="Clear" Width="80" Click="ClearVariablesButton_Click" />
                            </StackPanel>
                            <TextBox Grid.Row="1"
                                     Text="{Binding VariablesPreview}"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsReadOnly="True" />
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
